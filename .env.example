# ── MQTT ──────────────────────────────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_PROMPT_TOPIC=gemini2mqtt/prompt

# ── General ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ── Gemini CLI ─────────────────────────────────────────────────────────────────
GEMINI_CLI_PATH=gemini
GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_MAX_CONCURRENT=2
# GEMINI_TIMEOUT_SECONDS=120
# GEMINI_RETRY_COUNT=3
# GEMINI_KEEPALIVE_ENABLED=true   # Set to false to disable the daily Gemini ping (recommended for Vertex AI)

# Path to local directory containing Gemini credentials (created via auth flow)
# GEMINI_CREDENTIALS_PATH=/path/to/.gemini

# ── Vertex AI (for docker-compose-vertexapi.yml only) ─────────────────────────
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global
# VERTEX_CREDENTIAL_FILE=/path/to/vertex_key.json
