# ── MQTT ──────────────────────────────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_PROMPT_TOPIC=gemini2mqtt/prompt

# ── Gemini CLI ─────────────────────────────────────────────────────────────────
GEMINI_CLI_PATH=gemini
GEMINI_MODEL=gemini-2.5-pro-preview-03-25

# ── Vertex AI (optional, only needed when use_vertex_api=true) ─────────────────
VERTEX_CLI_PATH=gemini
VERTEX_PROJECT=
VERTEX_LOCATION=europe-west3

# Path to your Google Cloud service account JSON (optional)
# GCLOUD_CREDENTIALS_PATH=/path/to/credentials.json
