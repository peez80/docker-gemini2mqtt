# ── MQTT ──────────────────────────────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_PROMPT_TOPIC=gemini2mqtt/prompt

# ── General ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ── Gemini API ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_MAX_CONCURRENT=2
# GEMINI_TIMEOUT_SECONDS=120
# GEMINI_RETRY_COUNT=3

# ── AI Backend (Standard Gemini vs Vertex AI) ─────────────────────────────────
# AI_BACKEND=gemini

# ── Vertex AI ─────────────────────────────────────────────────────────────────
# If AI_BACKEND=vertex, the following variables can be set:
# VERTEX_GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# VERTEX_GOOGLE_CLOUD_LOCATION=global
# GOOGLE_APPLICATION_CREDENTIALS=/mnt/key/key.json
